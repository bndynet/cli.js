{
  "name": "@bndynet/cli",
  "version": "1.5.0",
  "description": "Powerful command line interface for interactive...",
  "main": "dist/cli.umd.js",
  "module": "dist/cli.es5.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "prebuild": "rimraf dist docs",
    "build": "tsc --emitDeclarationOnly && rollup --config ./rollup.config.mjs && npm run docs",
    "docs": "typedoc src/index.ts --out docs/api",
    "test": "npm run build && ts-node ./test/log.ts",
    "test:log": "ts-node ./test/log.ts",
    "test:io": "ts-node ./test/io.ts",
    "test:progress": "ts-node ./test/progress.ts",
    "test:question": "ts-node ./test/question.ts",
    "watch": "rollup --config ./rollup.config.mjs -w",
    "start": "concurrently --kill-others \"npm run watch\"",
    "site-serv": "npm run docs && npm run test:log && lite-server",
    "test:watch": "jest --coverage --watch",
    "test:prod": "npm run lint",
    "predeploy-gh-pages": "ts-node tools/gh-pages-prepare",
    "deploy-gh-pages": "npm run predeploy-gh-pages && ts-node tools/gh-pages-publish",
    "report-coverage": "cat ./coverage/lcov.info | coveralls",
    "release": "semantic-release",
    "init": "ts-node tools/init.ts",
    "prepublishOnly": "ts-node tools/inject-copyright",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "library",
    "sass",
    "typescript library",
    "UMD",
    "ES5"
  ],
  "author": {
    "name": "Bendy Zhang",
    "email": "zb@bndy.net"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bndynet/cli.js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "ora": "^9.3.0",
    "shelljs": "^0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/shelljs": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "coveralls": "^3.1.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^16.4.0",
    "lite-server": "^2.6.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-sass": "^1.15.3",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-typescript2": "^0.36.0",
    "semantic-release": "^24.2.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "prettier --write"
    ]
  }
}
